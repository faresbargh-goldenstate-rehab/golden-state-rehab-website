# ─────────────────────────────────────────────────────────────
# Golden State Rehab — Intake/VOB Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local for local dev (gitignored).
# In production: set these as Environment Variables in the
# Vercel dashboard → Project → Settings → Environment Variables.
# NEVER commit a real key to git.
# ─────────────────────────────────────────────────────────────

# Paubox HIPAA Email API
# Get these from https://dashboard.paubox.com after signing your BAA.
# PAUBOX_ENDPOINT_USERNAME is the "endpoint name" Paubox assigns you
# (usually matches your verified sending domain, e.g. "goldenstate-rehab").
PAUBOX_API_KEY=
PAUBOX_ENDPOINT_USERNAME=

# Sender address — must be on a domain you've verified in Paubox
# (DNS records: SPF, DKIM, return-path CNAME).
#
# NOTE: vob@goldenstate-rehab.com is a Google Workspace email group
# (distribution list, not a mailbox). Paubox can still send AS this
# address because Paubox signs the email with the domain's DKIM key —
# it doesn't need to authenticate against a real mailbox the way Gmail
# would. The benefit: when Noble Bill replies, the reply goes to the
# group and every member of the VOB team sees it.
#
# Requirement: the domain (goldenstate-rehab.com) must be fully
# verified in the Paubox dashboard (DKIM + SPF + return-path CNAME).
PAUBOX_FROM_EMAIL=vob@goldenstate-rehab.com

# Where VOB requests get delivered.
#
# ⚠️ TESTING PHASE: currently routed to Fares for verification.
# Change this to VOB@noblebill.com once the flow is confirmed
# end-to-end (sender domain verified, attachments arrive, replies
# go to the right place).
VOB_RECIPIENT_EMAIL=fares.bargh@goldenstate-rehab.com

# Optional: BCC a Golden State internal address for audit trail.
# Comment out if not needed. Must be on a HIPAA-safe inbox.
# VOB_BCC_EMAIL=
